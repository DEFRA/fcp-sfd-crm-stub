{
  "name": "fcp-sfd-crm-stub",
  "version": "0.0.0",
  "description": "fcp-sfd-crm-stub",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "NODE_ENV=development npm run server:watch",
    "dev:debug": "NODE_ENV=development npm run server:debug",
    "docker:build": "docker compose build",
    "docker:dev": "docker compose up",
    "format": "prettier --write \"**/*.{cjs,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{cjs,js,json,md}\"",
    "docker:test": "npm run lint && mkdir -p -m 755 coverage 2>/dev/null || true && docker compose -p fcp-sfd-crm-stub-test down -v && docker compose -f compose.yml -f compose.test.yml -p fcp-sfd-crm-stub-test run --build --rm fcp-sfd-crm-stub",
    "docker:test:watch": "docker compose -p fcp-sfd-crm-stub-test down -v && docker compose -f compose.yml -f compose.test.yml -f compose.test.watch.yml -p fcp-sfd-crm-stub-test run --build --rm fcp-sfd-crm-stub",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "postinstall": "npm run setup:husky",
    "server:debug": "nodemon --inspect-brk=0.0.0.0 --ext js,json --legacy-watch ./src",
    "server:watch": "nodemon --inspect=0.0.0.0 --ext js,json --legacy-watch ./src",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "start": "NODE_ENV=production node --use-strict .",
    "test": "TZ=UTC vitest run --coverage",
    "test:watch": "TZ=UTC vitest"
  },
  "imports": {
    "#/*": "./src/*"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@defra/hapi-secure-context": "0.4.0",
    "@defra/hapi-tracing": "1.30.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@hapi/boom": "10.0.1",
    "@hapi/hapi": "21.4.8",
    "convict": "6.2.5",
    "convict-format-with-validator": "6.2.0",
    "global-agent": "3.0.0",
    "hapi-pino": "13.0.0",
    "hapi-pulse": "3.0.1",
    "joi": "18.1.2",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "undici": "7.28.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.4",
    "eslint": "9.39.2",
    "husky": "9.1.7",
    "neostandard": "0.13.0",
    "nodemon": "3.1.10",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.2",
    "vitest": "4.1.4",
    "vitest-fetch-mock": "0.4.5"
  }
}
